logs/
*.log
npm-cache/
.cache/
node_modules/.cache/

# ==============================
# Test & coverage
# ==============================
coverage/
.nyc_output/
jest.config.js
test-results/

# ==============================
# Optional: ignore generated files in root (if any)
# ==============================
bundle.js
main.js
index.js